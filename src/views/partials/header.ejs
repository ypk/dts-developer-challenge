<header class="govuk-header" role="banner" data-module="govuk-header">
  <div class="govuk-header__container govuk-width-container">
    <div class="govuk-header__logo">
      <a href="/" class="govuk-header__link govuk-header__link--homepage">
        <%- getSVG('govuk-logotype.svg') %>
      </a>
    </div>
    <div class="govuk-header__content">
      <a href="/" class="govuk-header__link govuk-header__service-name">
        Case Management
      </a>
      <button type="button" class="govuk-header__menu-button govuk-js-header-toggle" aria-controls="navigation" hidden>
        Menu
      </button>
      <nav aria-label="Menu" class="govuk-header__navigation">
        <ul id="navigation" class="govuk-header__navigation-list">
          <li class="govuk-header__navigation-item <%= currentPath === '/cases' ? 'govuk-header__navigation-item--active' : '' %>">
            <a class="govuk-header__link" href="/cases">
              Cases
            </a>
          </li>
          <li class="govuk-header__navigation-item <%= currentPath === '/cases/new' ? 'govuk-header__navigation-item--active' : '' %>">
            <a class="govuk-header__link" href="/cases/new">
              New Case
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</header>
